#!/bin/bash
#
#	mkdir -p ~/tmp/kernel.org-5.10/patches.kernel.org
#	cd /gituser/linux-stable>
#	mk_format_patch . v5.10.40..v5.10.41 ~/tmp/kernel.org-5.10/patches.kernel.org
#	or
#	cd ~/tmp/kernel.org-5.10/
#	mk_patch_series '/gituser/linux-stable' v5.10.18..v5.10.19 "patches.kernel.org"
#	or
#	mk_patch_series '/gituser/linux-stable' HEAD~100..HEAD "patches.kernel.org"

used_f ()
{
	echo -e "$mess"
	echo -e "\n    Used:"
	echo -e "\n$0 <LOCAL GIT URL> <tag..tag> <patches.name dir>\n"
}

# intelect copy
# Copy only those patches that have changed their content,
# so as not to create unnecessary noise.
ii_cp()
{
	local new_p=$1
	local old_p=$2
	counter=0

	if [ "$(diff -N \
		--ignore-matching-lines="^From [0-9a-f]\{40\}" \
		--ignore-matching-lines="^index [0-9a-f]\{7\}" \
		$old_p $new_p 2>/dev/null)" != "" ]
	then
		cp --backup=none -f $new_p $old_p
		counter=1
	fi
}

mk_patch_series ()
{
	local url_t="${1}"
	if test -d "$url_t"; then url_t="$(realpath $url_t)"; fi
	local range="${2:-HEAD..HEAD}"
	local target="${3:-~/tmp}"
	if test -d $target; then target="$(realpath $target)"; fi

	local target_name
	local target_dir
	local mess=""

	echo -e "\nLOCAL GIT URL =: [\033[1;34m$url_t\033[0m]"
	echo -e "revision range =: [\033[1;34m$range\033[0m]"
	echo -e "target folder for patches =: [\033[1;34m$target\033[0m]\n"

	[ -d $url_t ] || mess+="  bad url [$url_t]\n"
	[ "$(git -C $url_t rev-parse --git-dir 2>/dev/null)" != ".git" ] && \
	mess+="  It's NOT git\n"

	[ $(git -C $url_t rev-list ${range%..*} -1 2>/dev/null) ] || \
	mess+="  bad first tag [${range%..*}]\n"

	[ $(git -C $url_t rev-list ${range#*..} -1 2>/dev/null) ] || \
	mess+="  bad second tag [${range#*..}]\n"

	[ -d $target ] || mess+="  bad target dir [$target]\n"

if [ "$mess" == "" ]
then
	local tmp_dir=$(mktemp -d /tmp/format_patch_XXXXXXX)
	local origin_url="$(git -C $url_t remote get-url origin 2>/dev/null)"

	echo "    It's generate format-patch: "
	echo "    In tmp folder: $tmp_dir"

	target_name="$(basename $target)"
	target_dir="$(dirname $target)"

	case "$(basename $url_t)" in
	linux-stable)
		numbered=true
		prefix="${range#*..v}-"
		sufix="kernel.org"
		;;
	megause|megause-linux)
		numbered=true
		t_branch="$(git -C $url_t branch --show-current)"
		prefix="o${t_branch#*-}-"
		sufix="${t_branch%%-*}${t_branch#*-}"
		;;
	*)
		if test "${target_name#*.}" != "$target_name"
		then
			sufix="${target_name#*.}"
		else
			sufix="conf"
		fi
		;;
	esac


	[ -f ${target_dir}/series.$sufix ] && \
	mv -f ${target_dir}/series.$sufix	${target_dir}/series.${sufix}.old

	echo -e "#\n#\tAutomatically generated by the script mk_format_patch\n#" \
			>${target_dir}/series.$sufix

	[ -n "$origin_url" ] && \
		echo -e "#\t${origin_url}\n#" >>${target_dir}/series.$sufix

	if test $numbered
	then
		$(git -C $url_t \
			format-patch $range \
			-o $tmp_dir/
		) 2>/dev/null

		echo -e "\t\tAll patches: [$(ls $tmp_dir | wc -l)]"
		$(cd $tmp_dir
			for pt in $(ls)
			do
				if test -s $pt
				then
					echo -e "\t$target_name/${prefix}${pt#*0}" \
						>> ${target_dir}/series.$sufix

					mv $pt ${target}/${prefix}${pt#*0}
				fi
			done
		)

	else
		mkdir $tmp_dir/$target_name
		sum_counter=0

		nc=$(git -C $url_t \
			log --reverse \
			--pretty=format:"%H" \
			$range
		)
		for com in $nc
		do
			nametmp=$(git -C $url_t \
						format-patch \
						$com -1 \
						-o $tmp_dir/
			)

			if test -s $nametmp
			then
				name_pt="$(echo $nametmp | \
					gawk '{
						sub(/^.*0001-/, "")
							print $0
					}'
				)"

				mv $nametmp $tmp_dir/$target_name/$name_pt
				echo -e "\t${target_name}/$name_pt" >> \
					$tmp_dir/series.$sufix

				ii_cp $tmp_dir/$target_name/$name_pt ${target}/$name_pt
				sum_counter=$(($sum_counter + $counter))
			fi
		done

		cat $tmp_dir/series.$sufix >>${target_dir}/series.$sufix

		echo -e "\t\tAll patches: [$(ls $tmp_dir/$target_name/ | wc -l)]"
		echo -e "\t\tReplaced the patches: [$sum_counter]"
	fi

	rm -rf $tmp_dir
else
	used_f
fi
}

mk_patch_series ${1} ${2} ${3}

