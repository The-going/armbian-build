From 4166c4b5e1c09963de6e9ce78f23aaaeb6109f99 Mon Sep 17 00:00:00 2001
From: Ondrej Jirman <megous@megous.com>
Date: Sun, 1 Nov 2020 02:53:02 +0100
Subject: [PATCH] arm64: dts: sunxi: Add mmc aliases

Support is available since 5.10

Signed-off-by: Ondrej Jirman <megous@megous.com>
Signed-off-by: The-Going <48602507+The-going@users.noreply.github.com>
---
 arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi  | 3 +++
 arch/arm64/boot/dts/allwinner/sun50i-h5-orangepi-pc2.dts | 1 +
 arch/arm64/boot/dts/allwinner/sun50i-h6-orangepi-3.dts   | 3 +++
 3 files changed, 7 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi b/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
index a0dd27177..20abae32d 100644
--- a/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
@@ -14,6 +14,9 @@
 
 / {
 	aliases {
+		mmc0 = &mmc0;
+		mmc1 = &mmc1;
+		mmc2 = &mmc2;
 		serial0 = &uart0;
 		ethernet0 = &rtl8723cs;
 	};
diff --git a/arch/arm64/boot/dts/allwinner/sun50i-h5-orangepi-pc2.dts b/arch/arm64/boot/dts/allwinner/sun50i-h5-orangepi-pc2.dts
index bd29a1c90..d5ea0bfee 100644
--- a/arch/arm64/boot/dts/allwinner/sun50i-h5-orangepi-pc2.dts
+++ b/arch/arm64/boot/dts/allwinner/sun50i-h5-orangepi-pc2.dts
@@ -21,6 +21,7 @@ reg_vcc3v3: vcc3v3 {
 	};
 
 	aliases {
+		mmc0 = &mmc0;
 		ethernet0 = &emac;
 		serial0 = &uart0;
 	};
diff --git a/arch/arm64/boot/dts/allwinner/sun50i-h6-orangepi-3.dts b/arch/arm64/boot/dts/allwinner/sun50i-h6-orangepi-3.dts
index e9c7cadf8..7fba0ee3a 100644
--- a/arch/arm64/boot/dts/allwinner/sun50i-h6-orangepi-3.dts
+++ b/arch/arm64/boot/dts/allwinner/sun50i-h6-orangepi-3.dts
@@ -13,6 +13,9 @@ / {
 	compatible = "xunlong,orangepi-3", "allwinner,sun50i-h6";
 
 	aliases {
+		mmc0 = &mmc0;
+		mmc1 = &mmc1;
+		mmc2 = &mmc2;
 		serial0 = &uart0;
 		serial1 = &uart1;
 		ethernet0 = &emac;
-- 
2.26.2

