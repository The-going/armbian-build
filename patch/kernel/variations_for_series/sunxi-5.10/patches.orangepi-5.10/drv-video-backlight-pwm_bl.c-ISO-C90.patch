From 09ecdacaa0d26daee7b91cf1489b039ca4109117 Mon Sep 17 00:00:00 2001
From: The Going <48602507+The-going@users.noreply.github.com>
Date: Fri, 2 Apr 2021 20:27:31 +0300
Subject: [PATCH] drv: video: backlight: pwm_bl.c ISO C90

---
 drivers/video/backlight/pwm_bl.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/video/backlight/pwm_bl.c b/drivers/video/backlight/pwm_bl.c
index a0538733b..70dca075b 100644
--- a/drivers/video/backlight/pwm_bl.c
+++ b/drivers/video/backlight/pwm_bl.c
@@ -455,6 +455,7 @@ static int pwm_backlight_probe(struct platform_device *pdev)
 	struct pwm_state state, state_real;
 	unsigned int i;
 	int ret;
+	u64 level;
 
 	if (!data) {
 		ret = pwm_backlight_parse_dt(&pdev->dev, &defdata);
@@ -636,7 +637,7 @@ static int pwm_backlight_probe(struct platform_device *pdev)
 		 * the brightness determined by the driver
 		 */
 		pwm_get_state(pb->pwm, &state);
-		u64 level = (u64)state.duty_cycle * pb->scale;
+		level = (u64)state.duty_cycle * pb->scale;
 		do_div(level, (u64)state.period);
 
 		for (i = 0; i <= data->max_brightness; i++) {
-- 
