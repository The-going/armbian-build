From b3f3897799e7a1fff4b5f9590b8d37e48ced5c0d Mon Sep 17 00:00:00 2001
From: Ondrej Jirman <megous@megous.com>
Date: Thu, 27 Aug 2020 12:54:30 +0200
Subject: [PATCH] arm64: dts: sun50i-a64-pinephone: Expose AXP temperature
 sensor as ADC

Why not?

Signed-off-by: Ondrej Jirman <megous@megous.com>
---
 arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi b/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
index cec0e3293..97d684987 100644
--- a/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
@@ -261,6 +261,10 @@ axp803: pmic@3a3 {
 
 #include "axp803.dtsi"
 
+&axp_adc {
+	x-powers,ts-as-gpadc;
+};
+
 &battery_power_supply {
 	status = "okay";
 };
