From a9d44d75f3f5ad2beef4fc711dcf30400965ed29 Mon Sep 17 00:00:00 2001
From: Ondrej Jirman <megous@megous.com>
Date: Mon, 30 Nov 2020 06:14:07 +0100
Subject: [PATCH] arm64: dts: sun50i-pinephone: Bump I2C frequency to 400kHz

High speed. :)

Signed-off-by: Ondrej Jirman <megous@megous.com>
---
 arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi b/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
index 4b0036854..a0dd27177 100644
--- a/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun50i-a64-pinephone.dtsi
@@ -458,6 +458,7 @@ ov5640_ep: endpoint {
 
 &i2c0 {
 	status = "okay";
+	clock-frequency = <400000>;
 
 	touchscreen@5d {
 		compatible = "goodix,gt917s";
@@ -475,6 +476,7 @@ touchscreen@5d {
 
 &i2c1 {
 	status = "okay";
+	clock-frequency = <400000>;
 
 	/* Magnetometer */
 	lis3mdl: lis3mdl@1e {
-- 
2.26.2

