From b7b09ca559caac86cdda15f973aea3dc270dc9fd Mon Sep 17 00:00:00 2001
From: The Going <48602507+The-going@users.noreply.github.com>
Date: Wed, 21 Apr 2021 18:49:37 +0300
Subject: [PATCH] general fix builddeb packaging

Signed-off-by: The Going <48602507+The-going@users.noreply.github.com>
---
 Makefile | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/Makefile b/Makefile
index fd5c8b5c0..f977aff47 100644
--- a/Makefile
+++ b/Makefile
@@ -401,7 +401,9 @@ export KCONFIG_CONFIG
 export KBUILD_DEFCONFIG := defconfig
 
 # SHELL used by kbuild
-CONFIG_SHELL := sh
+CONFIG_SHELL := $(shell if [ -x "$$BASH" ]; then echo $$BASH; \
+	  else if [ -x /bin/bash ]; then echo /bin/bash; \
+	  else echo sh; fi ; fi)
 
 HOST_LFS_CFLAGS := $(shell getconf LFS_CFLAGS 2>/dev/null)
 HOST_LFS_LDFLAGS := $(shell getconf LFS_LDFLAGS 2>/dev/null)
